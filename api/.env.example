# ── Base de datos ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5435        # En Docker prod usar 5432 (interno)
DB_NAME=dmario_b2b
DB_USER=dmario
DB_PASS=dmario_dev_2026

# ── Better Auth ───────────────────────────────────────────────────────────────
# PRODUCCIÓN: mínimo 32 caracteres aleatorios (openssl rand -base64 32)
BETTER_AUTH_SECRET=cambia_esto_en_produccion_min_32_chars
BETTER_AUTH_URL=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ── CORS (producción) ─────────────────────────────────────────────────────────
# Lista de orígenes permitidos, separados por coma.
# En desarrollo dejar vacío (permite todos los orígenes).
# CORS_ORIGINS=https://b2b.dmario.com.co,https://app.dmario.com.co

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000    # Ventana en ms (default 60 s)
THROTTLE_LIMIT=120    # Peticiones máx por ventana por IP (default 120)

# ── Wompi (obtener en https://comercios.wompi.co/) ────────────────────────────
WOMPI_PUB_KEY=pub_test_XXXXXXXXXXXXXXXXXXXXXXXX
WOMPI_PRIV_KEY=prv_test_XXXXXXXXXXXXXXXXXXXXXXXX
WOMPI_INTEGRITY_SECRET=test_integrity_XXXXXXXXXXXXXXXXXXXXXXXX
WOMPI_EVENTS_SECRET=test_events_XXXXXXXXXXXXXXXXXXXXXXXX
